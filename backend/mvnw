#!/usr/bin/env sh
set -e
BASE_DIR="$(cd "$(dirname "$0")"; pwd)"
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
JAR="$WRAPPER_DIR/maven-wrapper.jar"
PROPS="$WRAPPER_DIR/maven-wrapper.properties"
if [ ! -f "$JAR" ]; then
  URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.2.0/maven-wrapper-3.2.0.jar"
  if command -v curl >/dev/null 2>&1; then
    mkdir -p "$WRAPPER_DIR"
    curl -fsSL "$URL" -o "$JAR"
  elif command -v wget >/dev/null 2>&1; then
    mkdir -p "$WRAPPER_DIR"
    wget -q "$URL" -O "$JAR"
  else
    echo "curl or wget is required to download maven-wrapper.jar" >&2
    exit 1
  fi
fi
if [ -n "$JAVA_HOME" ]; then
  JAVA_CMD="$JAVA_HOME/bin/java"
else
  JAVA_CMD="java"
fi
exec "$JAVA_CMD" -Dmaven.multiModuleProjectDirectory="$BASE_DIR" -classpath "$JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
